    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// OpenAI 응답에서 title/tags 파싱\nlet title = '메모';\nlet tags = ['telegram'];\n\ntry {\n  const content = item?.choices?.[0]?.message?.content || '';\n  const parsed = JSON.parse(content);\n  if (parsed.title) {\n    title = parsed.title.replace(/[\\\\/:*?\"<>|]/g, '').replace(/\\s+/g, '_').slice(0, 40);\n  }\n  if (Array.isArray(parsed.tags)) tags = parsed.tags;\n} catch(e) {}\n\n// Prepare Message 데이터 가져오기\nconst prep = $('Prepare Message').first().json;\n\n// YAML frontmatter\nconst tagsYaml = tags.map(t => '  - ' + t).join('\\n');\nlet md = '---\\n';\nmd += 'date: ' + (prep.date_time_str || '') + '\\n';\nmd += 'source: telegram\\n';\nmd += 'type: ' + (prep.msg_type || 'text') + '\\n';\nif (prep.from_name) md += 'from: \"' + prep.from_name + '\"\\n';\nmd += 'tags:\\n' + tagsYaml + '\\n';\nmd += '---\\n\\n';\n\n// 본문\nconst msgType = prep.msg_type || 'text';\nif (msgType === 'photo') { md += '![[Telegram/attachments/' + prep.file_name + ']]\\n\\n';\n  if (prep.text) md += prep.text + '\\n';\n} else if (msgType === 'video') {\n  if (prep.file_name) md += '![[Telegram/attachments/' + prep.file_name + ']]\\n\\n';\n  md += '🎬 영상 길이: ' + (prep.video_duration || 0) + '초\\n\\n';\n  if (prep.text) md += prep.text + '\\n';\n} else if (msgType === 'document') {\n  md += '[[Telegram/attachments/' + prep.file_name + '|' + prep.file_name + ']]\\n\\n';\n  if (prep.text) md += prep.text + '\\n';\n} else {\n  md += prep.text || '';\n}\n\n// 파일명 / OneDrive 경로\nconst dateStr = prep.date_str || new Date().toISOString().slice(0, 10);\nconst fileNameMd = dateStr + '_' + title.replace(/_/g, ' ') + '.md';\n\nreturn [{\n  json: {\n    md_content: md,\n    file_name_md: fileNameMd,\n    onedrive_md_path: 'Telegram/' + dateStr + '/' + fileNameMd,\n    chat_id: prep.chat_id,\n    date_str: dateStr,\n    date_time_str: prep.date_time_str\n  }\n}];\n"
      },
      "id": "n14",
      "name": "Build MD Content",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
