      "id": "n01",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        496
      ],
      "webhookId": "05183659-4aad-4404-8386-fc8c4802734d",
