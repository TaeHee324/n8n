        "url": "=https://graph.microsoft.com/v1.0/me/drive/root:/%EC%98%B5%EC%8B%9C%EB%94%94%EC%96%B8/Startegy_Investment/{{ $('Prepare Message').item.json.onedrive_att_path || ('Telegram/attachments/' + $('Prepare Message').item.json.file_name) }}:/content",
