    {
      "parameters": {
        "jsCode": "const text = ($('Prepare Message').first().json.text || '').slice(0, 800);\n\nconst body = {\n  model: 'gpt-4o-mini',\n  messages: [\n    {\n      role: 'system',\n      content: '당신은 텔레그램 메시지를 분석해 옵시디언 노트의 제목과 태그를 생성하는 어시스턴트입니다.\\n\\n규칙:\\n- 제목: 메시지 핵심 내용을 담은 명사구, 한국어, 40자 이내, 특수문자 제외\\n- 태그: 핵심 키워드 2~5개, 한국어 허용, 소문자, 공백 없이'\n    },\n    {\n      role: 'user',\n      content: '다음 텔레그램 메시지의 제목과 태그를 생성해줘.\\n\\n메시지:\\n' + text\n    }\n  ],\n  response_format: {\n    type: 'json_schema',\n    json_schema: {\n      name: 'note_metadata',\n      strict: true,\n      schema: {\n        type: 'object',\n        properties: {\n          title: { type: 'string' },\n          tags: { type: 'array', items: { type: 'string' } }\n        },\n        required: ['title', 'tags'],\n        additionalProperties: false\n      }\n    }\n  },\n  max_tokens: 200\n};\n\nreturn [{ json: { openai_body: JSON.stringify(body) } }];\n"
      },
