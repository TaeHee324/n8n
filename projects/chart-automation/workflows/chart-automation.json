    {
      "parameters": {
        "jsCode": "// 환율/유가/채권 데이터 합산 -> AI Agent용 userMsg 조립\nconst items = $input.all();\nlet exchangeData = {}, oilData = {}, bondData = {};\nconst newsList = [];\n\nfor (const it of items) {\n  const d = it.json;\n  if (d.category === 'exchange') exchangeData = d;\n  else if (d.category === 'oil') oilData = d;\n  else if (d.category === 'bond') bondData = d;\n  if (d.news_text) newsList.push(d.news_text);\n}\n\nconst today = exchangeData.DATE || oilData.DATE || bondData.DATE\n  || new Date().toISOString().slice(0, 10);\n\nconst usdKrw = (() => {\n  for (const k of Object.keys(exchangeData)) {\n    if (k.includes('달러') || k.includes('USD') || k.includes('15:30')) return exchangeData[k];\n  }\n  return null;\n})();\nconst wti = (() => {\n  for (const k of Object.keys(oilData)) {\n    if (k.includes('WTI') || k.includes('유가') || k.includes('NYMEX')) return oilData[k];\n  }\n  return null;\n})();\nconst b3 = (() => {\n  for (const k of Object.keys(bondData)) {\n    if (k.includes('3년') || k.includes('3Y')) return bondData[k];\n  }\n  return null;\n})();\nconst b10 = (() => {\n  for (const k of Object.keys(bondData)) {\n    if (k.includes('10년') || k.includes('10Y')) return bondData[k];\n  }\n  return null;\n})();\n\nconst userMsg = [\n  '오늘 날짜: ' + today,\n  '달러-원 환율(15:30): ' + (usdKrw != null ? usdKrw + '원' : 'N/A'),\n  'WTI 유가: $' + (wti != null ? wti : 'N/A'),\n  '국채 3년: ' + (b3 != null ? b3 + '%' : 'N/A'),\n  '국채 10년: ' + (b10 != null ? b10 + '%' : 'N/A'),\n  '',\n  '관련 뉴스:',\n  newsList.join('\\n\\n') || '뉴스 없음'\n].join('\\n');\n\nreturn [{ json: { today, usdKrw, wti, b3, b10, userMsg } }];"
      },
