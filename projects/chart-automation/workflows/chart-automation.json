    {
      "parameters": {
        "jsCode": "// 채권 기사 파서\nconst item = $input.first().json;\nif (item.category !== 'bond') return [];\n\nconst text = (item.content || '').replace(/\\s+/g, ' ');\n\n// 날짜\nconst dateMatch = text.match(/입력 (\\d{4})\\.(\\d{2})\\.(\\d{2})/);\nconst date = dateMatch ? dateMatch[1]+'-'+dateMatch[2]+'-'+dateMatch[3] : new Date().toISOString().slice(0,10);\n\n// 3년물\nconst b3 = text.match(/국고채 3년물 최종호가 수익률은[^%]*?(\\d+\\.\\d+)%/);\n// 10년물\nconst b10 = text.match(/국고채 10년물 금리는[^%]*?(\\d+\\.\\d+)%/);\n\n// 뉴스 요약\nconst lead = text.match(/\\(서울=연합인포맥스\\)[^=]+= (.{20,300})\\./);\nconst newsText = lead ? lead[1].trim() : '';\n\nreturn [{ json: {\n  DATE: date,\n  '국고채권(3년)': b3 ? parseFloat(b3[1]) : null,\n  '국고채권(10년)': b10 ? parseFloat(b10[1]) : null,\n  news_text: newsText,\n  category: 'bond'\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1568,
        1376
      ],
      "id": "f64f37d6-6205-4210-9cae-c32dc4d72ec6",
      "name": "Parse Bond"
    },
    {
      "parameters": {
        "jsCode": "// 기사 제목으로 category 부여 + URL 추출\nconst item = $input.first().json;\nconst title = item.title || '';\nconst link = item.link || item.url || item.guid || '';\n\nlet category = null;\nif (title.includes('[서환-마감]')) category = 'exchange';\nelse if (title.includes('[채권-마감]')) category = 'bond';\nelse if (title.includes('[뉴욕유가]')) category = 'oil';\n\nif (!category) return [];\n\nreturn [{ json: { ...item, category, articleUrl: link } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
