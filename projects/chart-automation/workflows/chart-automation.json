      ],
      "id": "5c922a4e-0506-4df3-8402-0b1d9897d5e9",
      "name": "Parse Exchange"
    },
    {
      "parameters": {
        "jsCode": "// 유가 기사 파서\nconst item = $input.first().json;\nif (item.category !== 'oil') return [];\n\nconst text = (item.content || '').replace(/\\s+/g, ' ');\n\n// 날짜 (기사 날짜 - 1일: 뉴욕 마감은 전날 기준)\nconst dateMatch = text.match(/입력 (\\d{4})\\.(\\d{2})\\.(\\d{2})/);\nlet date;\nif (dateMatch) {\n  const d = new Date(`${dateMatch[1]}-${dateMatch[2]}-${dateMatch[3]}`);\n  d.setDate(d.getDate() - 1);\n  date = d.toISOString().slice(0, 10);\n} else {\n  const d = new Date();\n  d.setDate(d.getDate() - 1);\n  date = d.toISOString().slice(0, 10);\n}\n\n// WTI 종가: '배럴당 111.54달러에 마감'\nconst wtiMatch = text.match(/배럴당\\s*([\\d,]+\\.?\\d*)\\s*달러에 마감/);\nconst wti = wtiMatch ? parseFloat(wtiMatch[1].replace(/,/g,'')) : null;\n\n// 뉴스 요약\nconst lead = text.match(/\\((뉴욕|서울)=연합[^)]*\\)[^=]+= (.{20,300})\\./);\nconst newsText = lead ? lead[2].trim() : '';\n\nreturn [{ json: {\n  DATE: date,\n  'WTI유(NYMEX)': wti,\n  news_text: newsText,\n  category: 'oil'\n}}];\n"
      },
      "type": "n8n-nodes-base.code",
