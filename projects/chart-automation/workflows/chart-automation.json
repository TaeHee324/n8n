      "parameters": {
        "jsCode": "const items = $input.all();\n\n// 유효한 숫자값이 있는 행만 필터링하는 헬퍼 함수\nfunction hasValidValue(item, key) {\n  const v = item.json[key];\n  return v !== undefined && v !== null && v !== '' && !isNaN(parseFloat(v));\n}\n\n// 데이터 분류 및 날짜 오름차순 정렬\nconst 환율Data = items\n  .filter(i => hasValidValue(i, '원/달러(종가 15:30)'))\n  .sort((a, b) => new Date(a.json['DATE']) - new Date(b.json['DATE']));\n\nconst 유가Data = items\n  .filter(i => hasValidValue(i, 'WTI유(NYMEX)'))\n  .sort((a, b) => new Date(a.json['DATE']) - new Date(b.json['DATE']));\n\nconst 국고채Data = items\n  .filter(i => hasValidValue(i, '국고채권(3년)'))\n  .sort((a, b) => new Date(a.json['DATE']) - new Date(b.json['DATE']));\n\nfunction buildChart(labels, datasets, title) {\n  return {\n    type: 'line',\n    data: { labels, datasets },\n    options: {\n      title: { display: true, text: title, fontSize: 16 },\n      legend: { display: true },\n      scales: {\n        xAxes: [{ ticks: { maxTicksLimit: 10, maxRotation: 45 } }]\n      }\n    }\n  };\n}\n\nconst charts = [];\n\nif (환율Data.length > 0) {\n  charts.push({\n    chartName: '환율',\n    chart: buildChart(\n      환율Data.map(i => i.json['DATE']),\n      [\n        {\n          label: '원/달러(종가 02:00)',\n          data: 환율Data.map(i => parseFloat(i.json['원/달러(종가 02:00)']) || null),\n          borderColor: '#1565C0',\n          backgroundColor: 'rgba(21,101,192,0.1)',\n          fill: false,\n          tension: 0.1\n        },\n        {\n          label: '원/달러(종가 15:30)',\n          data: 환율Data.map(i => parseFloat(i.json['원/달러(종가 15:30)']) || null),\n          borderColor: '#42A5F5',\n          backgroundColor: 'rgba(66,165,245,0.1)',\n          fill: false,\n          tension: 0.1\n        }\n      ],\n      'USD/KRW 환율'\n    )\n  });\n}\n\nif (유가Data.length > 0) {\n  charts.push({\n    chartName: '유가',\n    chart: buildChart(\n      유가Data.map(i => i.json['DATE']),\n      [\n        {\n          label: 'WTI유(NYMEX)',\n          data: 유가Data.map(i => parseFloat(i.json['WTI유(NYMEX)']) || null),\n          borderColor: '#E65100',\n          backgroundColor: 'rgba(230,81,0,0.1)',\n          fill: true,\n          tension: 0.1\n        }\n      ],\n      'WTI 유가'\n    )\n  });\n}\n\nif (국고채Data.length > 0) {\n  charts.push({\n    chartName: '국고채',\n    chart: buildChart(\n      국고채Data.map(i => i.json['DATE']),\n      [\n        {\n          label: '국고채(3년)',\n          data: 국고채Data.map(i => parseFloat(i.json['국고채권(3년)']) || null),\n          borderColor: '#2E7D32',\n          fill: false,\n          tension: 0.1\n        },\n        {\n          label: '국고채(10년)',\n          data: 국고채Data.map(i => parseFloat(i.json['국고채권(10년)']) || null),\n          borderColor: '#FF8F00',\n          fill: false,\n          tension: 0.1\n        },\n      ],\n      '국고채 금리'\n    )\n  });\n}\n\nreturn charts.map(c => ({\n  json: {\n    chartName: c.chartName,\n    width: 800,\n    height: 400,\n    backgroundColor: 'white',\n    chart: c.chart\n  }\n}));\n"
      },
