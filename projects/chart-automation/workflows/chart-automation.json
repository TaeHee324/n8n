    {
      "parameters": {
        "jsCode": "// 환율 기사 파서\nconst item = $input.first().json;\nif (item.category !== 'exchange') return [];\n\nconst text = (item.content || '').replace(/\\s+/g, ' ');\n\n// 날짜: '입력 2026.04.03'\nconst dateMatch = text.match(/입력 (\\d{4})\\.(\\d{2})\\.(\\d{2})/);\nconst date = dateMatch ? dateMatch[1]+'-'+dateMatch[2]+'-'+dateMatch[3] : new Date().toISOString().slice(0,10);\n\n// 15:30 정규장 종가\nconst c15 = text.match(/오후 3시 30분 기준으로.+?([1-9],?\\d{3}\\.\\d+)원에 정규장/);\nconst usd_krw_1530 = c15 ? parseFloat(c15[1].replace(/,/g,'')) : null;\n\n// 시가 (전날 NDF)\nconst cOpen = text.match(/전날 대비.+?([1-9],?\\d{3}\\.\\d+)원에서 거래를 시작/);\nconst usd_krw_0200 = cOpen ? parseFloat(cOpen[1].replace(/,/g,'')) : null;\n\n// 뉴스 요약 (리드 문단)\nconst lead = text.match(/\\(서울=연합인포맥스\\)[^=]+= (.{20,300})\\./);\nconst newsText = lead ? lead[1].trim() : '';\n\nreturn [{ json: {\n  DATE: date,\n  '원/달러(종가 15:30)': usd_krw_1530,\n  '원/달러(종가 02:00)': usd_krw_0200,\n  news_text: newsText,\n  category: 'exchange'\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
